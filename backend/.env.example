# ---- Database ----
# When running with docker-compose, host is the service name "db".
# When running locally without docker, use localhost.
DATABASE_URL=postgresql://viva_user:viva_pass@db:5432/viva_db

# ---- Auth / JWT ----
JWT_SECRET=change-this-to-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ---- Gemini (Google GenAI) ----
# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key
# Current flash models include gemini-2.5-flash and the newer gemini-3.5-flash.
# Check Google AI Studio for what your key has access to, then set it here.
GEMINI_MODEL=gemini-2.5-flash

# ---- CORS ----
# Comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:5173
