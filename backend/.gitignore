cd /path/to/your/ai-viva-project
cat > .gitignore << 'EOF'
# Secrets / env
.env
.env.local
.env.*.local

# Python (backend)
__pycache__/
*.py[cod]
.venv/
venv/
*.egg-info/
.pytest_cache/

# Database (SQLite) — *.db already covers _test_smoke.db
*.db

# Node / frontend (Vite)
node_modules/
dist/

# Logs
*.log

# OS / editor
.DS_Store
.vscode/
.idea/
EOF